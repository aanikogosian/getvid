# Token from @BotFather.
TELEGRAM_BOT_TOKEN=123456:change-me

# Root URL of your already running local Telegram Bot API server.
TELEGRAM_API_ROOT=http://127.0.0.1:8081

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# ALLOWED_USER_IDS=111111111,222222222

DOWNLOAD_DIR=./downloads
MAX_CONCURRENT_DOWNLOADS=2
REQUEST_TIMEOUT_SECONDS=3600

# Optional cookies for sites that require login/age checks.
# Export them in Netscape format, e.g. with a browser extension.
# YTDLP_COOKIES=/opt/getvid/cookies.txt
